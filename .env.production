# ISLI — Production Environment Template
# DO NOT commit secrets. Load via CI/CD secrets manager or AWS Secrets Manager.
ISLI_ENV=production

# --- Core API ---
DATABASE_URL=${DATABASE_URL:?error}
REDIS_URL=${REDIS_URL:?error}
JWT_SECRET=${JWT_SECRET:?error}
KEEPER_URL=${KEEPER_URL:?error}
CORE_API_URL=${CORE_API_URL:?error}
OTEL_SERVICE_NAME=isli-core
CORS_ORIGINS=${CORS_ORIGINS:?error}
TLS_CERT_PATH=${TLS_CERT_PATH}
TLS_KEY_PATH=${TLS_KEY_PATH}
PII_ENCRYPTION_KEY=${PII_ENCRYPTION_KEY:?error}
ADMIN_API_KEY=${ADMIN_API_KEY:?error}

# --- Keeper ---
OLLAMA_HOST=${OLLAMA_HOST:?error}
OLLAMA_EMBED_MODEL=${OLLAMA_EMBED_MODEL:-nomic-embed-text}
OLLAMA_GEN_MODEL=${OLLAMA_GEN_MODEL:-qwen3:1.7b}
KEEPER_FALLBACK_MODEL=${KEEPER_FALLBACK_MODEL}
KEEPER_IDENTITY=${KEEPER_IDENTITY:-isli-keeper}
OLLAMA_API_KEY=${OLLAMA_API_KEY}

# --- Channels ---
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}
WEBHOOK_SECRET=${WEBHOOK_SECRET}

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=${OTEL_EXPORTER_OTLP_ENDPOINT}

# --- Agent API Keys (populate if cloud fallback is enabled) ---
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY}
GOOGLE_API_KEY=${GOOGLE_API_KEY}
