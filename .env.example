# ISLI — Minimal .env for Docker Compose (VPS/PC)
# Copy this file to .env and fill in the required secrets.
# All other variables have defaults or are constructed inside docker-compose.yml.

# --- Required: PostgreSQL ---
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Required: JWT signing (must be >= 32 bytes) ---
JWT_SECRET=change-me-to-a-32-byte-secret-or-longer!!!

# --- Required: PII encryption (must be >= 32 bytes) ---
PII_ENCRYPTION_KEY=change-me-to-a-32-byte-key-or-longer!!!!

# --- Required: Admin API Key (used by the board for mutations) ---
ADMIN_API_KEY=isli-admin-dev-key

# --- Required: Internal service auth ---
# Used by Core to sign webhook payloads sent to Channels and to authenticate
# with the Skills registry. Must be set in production.
WEBHOOK_SECRET=change-me-webhook-secret-32-bytes-min
SKILL_REGISTRY_TOKEN=change-me-skill-registry-token-32-bytes-min

# --- Optional: Default agent ID for static agent-runner service ---
# Core spawns agents dynamically; this is only used if the static agent-runner
# service is enabled (deploy.replicas > 0).
# AGENT_ID=kimi-02

# --- Optional: CORS (defaults to http://localhost) ---
# CORS_ORIGINS=http://localhost,https://your-domain.com

# --- Required for Production (Traefik Host rule) ---
ISLI_DOMAIN=isli.example.com

# --- Optional: Cloud API keys (only if you want cloud LLM fallback) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Optional: Channel integrations ---
# TELEGRAM_BOT_TOKEN=...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...

# WhatsApp Channel (WhatsApp Web via Baileys sidecar)
# Set to true to enable WhatsApp channel support.
# Each agent requires a separate WhatsApp account (phone number) and QR code pairing.
# WHATSAPP_ENABLED=false

# --- Required if WHATSAPP_ENABLED=true ---
# SIDECAR_WEBHOOK_SECRET=change-me-sidecar-webhook-secret
# SIDECAR_API_TOKEN=change-me-sidecar-api-token

# --- Optional: Skill service URLs (defaults inside docker-compose.yml) ---
# SKILL_SUMMARIZE_TEXT_URL=http://skills:8100
# SKILL_EMBED_TEXT_URL=http://skills:8100

# --- Optional: Audio model settings (defaults in docker-compose.yml) ---
# AUDIO_STT_MODEL=whisper-tiny
# AUDIO_TTS_MODEL=piper-en-us-lessac-medium
# AUDIO_LANGUAGE=en

# --- Optional: Override service images (defaults to ghcr.io/medelmouhajir/*:latest) ---
# DOCKER_REGISTRY=ghcr.io/your-org
# CORE_API_IMAGE=${DOCKER_REGISTRY}/isli-core:sha1234
# KEEPER_IMAGE=${DOCKER_REGISTRY}/isli-keeper:sha1234
# CHANNELS_IMAGE=${DOCKER_REGISTRY}/isli-channels:sha1234
# SKILLS_IMAGE=${DOCKER_REGISTRY}/isli-skills:sha1234
# BOARD_IMAGE=${DOCKER_REGISTRY}/isli-board:sha1234
