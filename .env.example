# ISLI — Minimal .env for Docker Compose (VPS/PC)
# Copy this file to .env and fill in the required secrets.
# All other variables have defaults or are constructed inside docker-compose.yml.

# --- Required: PostgreSQL ---
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Required: JWT signing (must be >= 32 bytes) ---
JWT_SECRET=change-me-to-a-32-byte-secret-or-longer!!!

# --- Required: PII encryption (must be >= 32 bytes) ---
PII_ENCRYPTION_KEY=change-me-to-a-32-byte-key-or-longer!!!!

# --- Optional: CORS (defaults to http://localhost) ---
# CORS_ORIGINS=http://localhost,https://your-domain.com

# --- Optional: Cloud API keys (only if you want cloud LLM fallback) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Optional: Channel integrations ---
# TELEGRAM_BOT_TOKEN=...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...

# --- Optional: Override service images (defaults to ghcr.io/medelmouhajir/*:latest) ---
# CORE_API_IMAGE=ghcr.io/medelmouhajir/isli-core:sha1234
# KEEPER_IMAGE=ghcr.io/medelmouhajir/isli-keeper:sha1234
# CHANNELS_IMAGE=ghcr.io/medelmouhajir/isli-channels:sha1234
# SKILLS_IMAGE=ghcr.io/medelmouhajir/isli-skills:sha1234
# BOARD_IMAGE=ghcr.io/medelmouhajir/isli-board:sha1234
