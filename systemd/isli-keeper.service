[Unit]
Description=ISLI Keeper
After=network.target redis-server.service
Wants=redis-server.service

[Service]
Type=simple
User=isli
Group=isli
WorkingDirectory=/opt/isli/isli-keeper
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/isli/.env
ExecStart=/opt/isli/isli-keeper/.venv/bin/python -m uvicorn isli_keeper.main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
